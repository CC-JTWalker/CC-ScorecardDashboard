{
  "name": "scorecard-radar",
  "version": "1.0.0",
  "description": "Desktop dashboard for reviewing OpenSSF Scorecard JSON reports and contextual vulnerability risk.",
  "main": "src/main.js",
  "author": "OpenAI",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.openai.scorecardradar",
    "productName": "Scorecard Radar",
    "files": [
      "src/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
